      <column caption='Male Count' datatype='integer' name='[Calculation_1740035391287297]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Gender]= &quot;Male&quot; THEN 1 &#13;&#10;ELSE 0 &#13;&#10;END' />
