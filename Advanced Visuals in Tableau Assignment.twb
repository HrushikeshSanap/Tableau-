      <column caption='Female Count' datatype='integer' name='[Calculation_1740035391553538]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Gender] = &quot;Female&quot; THEN 1 &#13;&#10;ELSE 0 &#13;&#10;END' />
      </column>
      <column caption='Male Negative' datatype='integer' name='[Calculation_1740035391934467]' role='measure' type='quantitative'>
