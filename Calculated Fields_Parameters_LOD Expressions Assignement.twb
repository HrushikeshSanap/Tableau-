      <aliases enabled='yes' />
      <column caption='Delivery Performance Classification ' datatype='string' name='[Calculation_1542947607728128]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Delivery_Time_Min]&lt;=30 THEN &quot;Fast&quot;&#13;&#10;ELSE &quot;Delayed&quot;&#13;&#10;END' />
      </column>
      <column caption='Loss Orders' datatype='string' name='[Calculation_1542947611602945]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Profit])&lt; 0 THEN &quot;Loss&quot;&#13;&#10;ELSE &quot;Profit&quot;&#13;&#10;END' />
      </column>
      <column caption='Product Rank' datatype='integer' name='[Calculation_1542947618357250]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Sales]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Avg Sales per City (FIXED)' datatype='real' name='[Calculation_1542947621769220]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [City] : AVG([Sales]) }' />
      </column>
      <column caption='Avg Sales per Product (INCLUDE)' datatype='real' name='[Calculation_1542947622600709]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ INCLUDE [Product_Name] : AVG([Sales]) }' />
      </column>
