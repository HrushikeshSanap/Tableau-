    <worksheet name='Task5'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Task 5: Customer/Product Detail Impact (INCLUDE LOD) Business Need The sales team wants average sales considering product-level detail, even when product is not shown. Task Create a calculation that finds the average sales at the product level, but allows the result to be used at a higher level (such as Category or Region). Use INCLUDE LOD. </run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Blinkit Orders Dataset)' name='federated.15lue1n0sgzgyg13w7ich1k6dhbp' />
          </datasources>
          <datasource-dependencies datasource='federated.15lue1n0sgzgyg13w7ich1k6dhbp'>
            <column caption='Avg Sales per Product (INCLUDE)' datatype='real' name='[Calculation_1542947622600709]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ INCLUDE [Product_Name] : AVG([Sales]) }' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal' />
            <column caption='Product Name' datatype='string' name='[Product_Name]' role='dimension' type='nominal' />
            <column datatype='integer' name='[Sales]' role='measure' type='quantitative' />
            <column-instance column='[Sales]' derivation='Avg' name='[avg:Sales:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Category]' derivation='None' name='[none:Category:nk]' pivot='key' type='nominal' />
            <column-instance column='[Product_Name]' derivation='None' name='[none:Product_Name:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1542947622600709]' derivation='Sum' name='[sum:Calculation_1542947622600709:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.15lue1n0sgzgyg13w7ich1k6dhbp].[none:Product_Name:nk]'>
            <groupfilter function='level-members' level='[none:Product_Name:nk]' user:ui-enumeration='all' user:ui-marker='enumerate' />
