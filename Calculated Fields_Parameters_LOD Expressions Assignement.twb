    <worksheet name='Task3'>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Blinkit Orders Dataset)' name='federated.15lue1n0sgzgyg13w7ich1k6dhbp' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Top N' datatype='integer' name='[Parameter 1]' param-domain-type='range' role='measure' type='quantitative' value='6'>
              <calculation class='tableau' formula='6' />
              <range granularity='1' max='50' min='1' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.15lue1n0sgzgyg13w7ich1k6dhbp'>
            <column caption='Product Name' datatype='string' name='[Product_Name]' role='dimension' type='nominal' />
            <column datatype='integer' name='[Sales]' role='measure' type='quantitative' />
            <column-instance column='[Product_Name]' derivation='None' name='[none:Product_Name:nk]' pivot='key' type='nominal' />
            <column-instance column='[Sales]' derivation='Sum' name='[sum:Sales:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.15lue1n0sgzgyg13w7ich1k6dhbp].[none:Product_Name:nk]'>
            <groupfilter count='[Parameters].[Parameter 1]' end='top' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='SUM([Sales])' function='order' user:ui-marker='order'>
                <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
                  <groupfilter function='member' level='[none:Product_Name:nk]' member='&quot;Apple&quot;' />
                  <groupfilter function='member' level='[none:Product_Name:nk]' member='&quot;Banana&quot;' />
                  <groupfilter function='member' level='[none:Product_Name:nk]' member='&quot;Bread&quot;' />
                  <groupfilter function='member' level='[none:Product_Name:nk]' member='&quot;Chips&quot;' />
                  <groupfilter function='member' level='[none:Product_Name:nk]' member='&quot;Cold Drink&quot;' />
                  <groupfilter function='member' level='[none:Product_Name:nk]' member='&quot;Curd&quot;' />
                  <groupfilter function='member' level='[none:Product_Name:nk]' member='&quot;Juice&quot;' />
                  <groupfilter function='member' level='[none:Product_Name:nk]' member='&quot;Milk&quot;' />
                </groupfilter>
              </groupfilter>
            </groupfilter>
          </filter>
          <shelf-sorts>
            <shelf-sort-v2 dimension-to-sort='[federated.15lue1n0sgzgyg13w7ich1k6dhbp].[none:Product_Name:nk]' direction='DESC' is-on-innermost-dimension='true' measure-to-sort-by='[federated.15lue1n0sgzgyg13w7ich1k6dhbp].[sum:Sales:qk]' shelf='rows' />
          </shelf-sorts>
          <slices>
            <column>[federated.15lue1n0sgzgyg13w7ich1k6dhbp].[none:Product_Name:nk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
            <encodings>
              <text column='[federated.15lue1n0sgzgyg13w7ich1k6dhbp].[sum:Sales:qk]' />
