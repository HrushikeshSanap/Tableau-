          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Task 1: Delivery Performance Classification (Calculated Field)</run>
            <run>Æ&#10;&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Insights:- Below is the tables where you can find which order is delayed and which is fast</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Blinkit Orders Dataset)' name='federated.15lue1n0sgzgyg13w7ich1k6dhbp' />
          </datasources>
          <datasource-dependencies datasource='federated.15lue1n0sgzgyg13w7ich1k6dhbp'>
            <column caption='Delivery Performance Classification ' datatype='string' name='[Calculation_1542947607728128]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Delivery_Time_Min]&lt;=30 THEN &quot;Fast&quot;&#13;&#10;ELSE &quot;Delayed&quot;&#13;&#10;END' />
            </column>
            <column caption='Delivery Time Min' datatype='integer' name='[Delivery_Time_Min]' role='measure' type='quantitative' />
            <column caption='Order ID' datatype='integer' name='[Order_ID]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_1542947607728128]' derivation='None' name='[none:Calculation_1542947607728128:nk]' pivot='key' type='nominal' />
            <column-instance column='[Order_ID]' derivation='None' name='[none:Order_ID:ok]' pivot='key' type='ordinal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='cell'>
            <format attr='width' field='[federated.15lue1n0sgzgyg13w7ich1k6dhbp].[none:Calculation_1542947607728128:nk]' value='532' />
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
            <encodings>
              <text column='[federated.15lue1n0sgzgyg13w7ich1k6dhbp].[none:Order_ID:ok]' />
            </encodings>
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-show' value='true' />
                <format attr='mark-labels-cull' value='true' />
              </style-rule>
              <style-rule element='pane'>
                <format attr='minwidth' value='-1' />
                <format attr='maxwidth' value='-1' />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows />
        <cols>[federated.15lue1n0sgzgyg13w7ich1k6dhbp].[none:Calculation_1542947607728128:nk]</cols>
      </table>
